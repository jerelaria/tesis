*.pth
*.ckpt
*.safetensors
*.bin

# ── Experiment results and outputs ───────────────────────
results/

# ── Notebook artifact images (auto-generated) ────────────
notebooks/*.png
notebooks/*.jpg

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

