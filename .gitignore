# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ──────────────────────────────────
venv/
.venv/
env/

# ── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

